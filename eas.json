{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PLATFORM": "native"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PLATFORM": "native"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PLATFORM": "native"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "6782215100",
        "ascAppId": "com.gamiwallet.app",
        "appleTeamId": "28DWZWQ4YG"
      },
      "android": {
        "serviceAccountKeyPath": "$ANDROID_SERVICE_ACCOUNT_KEY_PATH",
        "track": "production"
      }
    }
  }
}
